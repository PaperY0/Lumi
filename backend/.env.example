# DeepSeek API Key. Leave empty to run in mock mode.
DEEPSEEK_API_KEY=

# true = use mock data, false = call the real LLM when DEEPSEEK_API_KEY exists.
MOCK_MODE=true

# Backend port.
PORT=3001

# Comma-separated browser origins allowed to call the backend.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080

# Global rate limit: default 100 requests per 15 minutes per IP.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# AI route rate limit: default 30 requests per 15 minutes per IP.
AI_RATE_LIMIT_MAX=30

# MinerU token is used only by the backend proxy.
MINERU_TOKEN=
